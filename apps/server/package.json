{
  "name": "server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-arm64 --outfile ./dist/server ./src/index.ts",
    "build:linux": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile ./dist/server ./src/index.ts",
    "build:linux-arm64": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-linux-arm64 --outfile ./dist/server ./src/index.ts",
    "build:mac-x64": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-x64 --outfile ./dist/server ./src/index.ts",
    "build:windows": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile ./dist/server.exe ./src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev --name $(date)",
    "db:studio": "bunx prisma studio",
    "db:reset": "bunx prisma migrate reset",
    "test": "bun test tests",
    "test:watch": "bun test --watch tests",
    "coverage:report": "bun test --coverage tests"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@repo/shared": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "consola": "^3.4.2",
    "prisma": "^7.7.0"
  }
}
