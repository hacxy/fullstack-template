{
  "name": "server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev --name $(date)",
    "db:studio": "bunx prisma studio",
    "db:reset": "bunx prisma migrate reset"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@repo/shared": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "consola": "^3.4.2",
    "prisma": "^7.7.0"
  }
}
